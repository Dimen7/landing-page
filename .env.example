# --- General Website Information ---
# Your name or handle displayed as the main title
PUBLIC_NAME=""
# Meta description for SEO and social sharing
PUBLIC_DESCRIPTION=""
# Browser theme color (used for mobile status bars)
PUBLIC_THEME_COLOR="#000000"
# Optional profile image URL (leave empty to use the built-in generated avatar)
PUBLIC_IMAGE=""
# Optional favicon URL (leave empty to use the built-in generated favicon)
PUBLIC_FAVICON=""

# --- Theme & Branding (CSS Variables) ---
# Main text color (usually light gray/white)
PUBLIC_COLOR_WHITE="#cccccc"
# Secondary color (used for scrollbars, etc.)
PUBLIC_COLOR_GRAY="#333333"
# Accent color (used for links, hover effects, and cursor glow)
PUBLIC_COLOR_HIGHLIGHT="#ff0052"
# Main background color of the site
PUBLIC_COLOR_BG="#060606"

# --- Visual Effects ---
# Texture used for the cursor trail noise effect
PUBLIC_CURSOR_NOISE_URL="https://s3-us-west-2.amazonaws.com/s.cdpn.io/982762/noise.png"
# Lerp factor for cursor trail follow speed (0.0–1.0, lower = smoother/slower)
PUBLIC_CURSOR_DIVISOR="0.2"
# Optional YouTube video ID(s) to play as background on first click
# Single video: loops indefinitely
# Multiple videos (comma-separated): randomly shuffled, auto-advances when current ends
# Examples: "dQw4w9WgXcQ" or "id1,id2,id3"
PUBLIC_BG_VIDEO_ID=""
# Blur intensity for background video(s) in pixels (default: 8)
PUBLIC_BG_VIDEO_BLUR="8"
# Initial volume for background video(s) (0–100, default: 50)
PUBLIC_BG_VIDEO_VOLUME="50"

# --- Localization & Personal Data ---
# Locale for date/time formatting (e.g., en-US, de-DE)
PUBLIC_LOCALE="en-US"
# Timezone for the clock (e.g., Europe/Berlin, UTC)
PUBLIC_TIMEZONE="UTC"
# Your physical location displayed in the bio
PUBLIC_LOCATION=""
# Your birthday in YYYY-MM-DD format (used to calculate your age automatically)
PUBLIC_BIRTHDAY="2000-01-01"
# Text displayed after your age (e.g., "years old")
PUBLIC_AGE_SUFFIX="years old"

# --- Bio ---
# Your main introduction text. Supports multiple sentences.
PUBLIC_BIO=""

# --- Social Media Links ---
# Add any social link by using the prefix PUBLIC_SOCIAL_ followed by an ICON_NAME.
# If an ICON_NAME is not found, it will fall back to a generic link icon.
# A full list of supported icon identifiers can be found in SOCIALS.md.
PUBLIC_SOCIAL_ENVELOPE=""
PUBLIC_SOCIAL_GITHUB=""
PUBLIC_SOCIAL_TWITTER=""
PUBLIC_SOCIAL_DISCORD=""
